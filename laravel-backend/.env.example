APP_NAME=Sonix
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://yourdomain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_LEVEL=error

# === Database (PostgreSQL recommended, MySQL also supported) ===
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=sonix
DB_USERNAME=postgres
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# === Redis (optional — feeds fall back gracefully if unavailable) ===
CACHE_STORE=redis
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# === Reverb (WebSockets — optional without real-time) ===
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_APP_ID=
REVERB_HOST=localhost
REVERB_PORT=443
REVERB_SCHEME=https

# === Mail (for password reset) ===
MAIL_MAILER=log
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="hello@sonix.app"
MAIL_FROM_NAME="${APP_NAME}"

# === Media / Watermark ===
MEDIA_WATERMARK_TEXT=${APP_NAME}
MEDIA_WATERMARK_ENABLED=false

# === Cloudinary (Media Storage) ===
# Sign up at https://cloudinary.com (free tier available)
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# === Expo Push Notifications ===
# Get from https://expo.dev
EXPO_ACCESS_TOKEN=your_expo_access_token

# === Rate Limiting ===
RATE_LIMIT_ENABLED=true
